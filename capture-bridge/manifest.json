{
  "manifest_version": 3,
  "name": "Rental Tracker Capture Bridge",
  "version": "2.1.1",
  "description": "Tees rental-listing API responses from property portals while you browse and syncs them into your local Rental Tracker page. Everything stays on your machine.",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "tabs"
  ],
  "background": {
    "service_worker": "sw.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Rental Tracker Capture"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.nobroker.in/*",
        "https://www.99acres.com/*",
        "https://housing.com/*",
        "https://www.magicbricks.com/*",
        "https://www.squareyards.com/*"
      ],
      "js": [
        "interceptor.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://www.nobroker.in/*",
        "https://www.99acres.com/*",
        "https://housing.com/*",
        "https://www.magicbricks.com/*",
        "https://www.squareyards.com/*"
      ],
      "js": [
        "relay.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "file:///*",
        "https://hemang-dwivedi.github.io/*"
      ],
      "js": [
        "bridge.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://www.nobroker.in/*",
    "https://www.99acres.com/*",
    "https://housing.com/*",
    "https://www.magicbricks.com/*",
    "https://www.squareyards.com/*"
  ]
}